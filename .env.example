# Supabase — NORBOT CRM
# Copia este archivo a .env.local y completa con tus credenciales.

# Públicas (seguras para el navegador)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Solo servidor — NUNCA exponer al cliente (usada por scripts/seed.ts)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Resend (correos) — si RESEND_API_KEY está vacío, los envíos se omiten sin romper nada
RESEND_API_KEY=re_...
# Remitente; sin dominio verificado deja onboarding@resend.dev (solo entrega al dueño de la cuenta Resend)
RESEND_FROM="NORBOT CRM <onboarding@resend.dev>"

# Cron de Vercel: protege /api/cron/* (genera uno con: openssl rand -hex 24)
CRON_SECRET=...

# URL del CRM para los enlaces de los correos
APP_URL=https://tu-dominio.vercel.app

# Bot de WhatsApp ↔ Claude — si faltan, el webhook /api/whatsapp queda inerte
ANTHROPIC_API_KEY=sk-ant-...
WHATSAPP_BOT_MODEL=claude-haiku-4-5
WHATSAPP_TOKEN=...                 # access token de la app de Meta (WhatsApp)
WHATSAPP_PHONE_NUMBER_ID=...       # id del número emisor
WHATSAPP_VERIFY_TOKEN=...          # texto secreto que tú eliges para verificar el webhook
